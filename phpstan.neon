parameters:
    level: 4
    paths:
        - lequocanh/app
        - lequocanh/includes
        - lequocanh/api
    excludePaths:
        - */vendor/*
        - */cache/*
        - */graphify-out/*
        - */node_modules/*
    bootstrapFiles:
        - lequocanh/includes/helpers.php
        - lequocanh/cache/QueryCache.php
    ignoreErrors:
        # Legacy classes loaded via require (not autoload)
        - '#on an unknown class (Database|SessionManager|GioHang|CacheManager|ConfigManager)#'
        # Active Record pattern - unsafe new static()
        - '#Unsafe usage of new static\(\)#'
