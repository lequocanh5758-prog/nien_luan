parameters:
    level: 4
    paths:
        - lequocanh/app
        - lequocanh/includes
        - lequocanh/api
    excludePaths:
        - */vendor/*
        - */cache/*
        - */graphify-out/*
        - */node_modules/*
    bootstrapFiles:
        - lequocanh/includes/helpers.php
        - lequocanh/administrator/elements_LQA/mod/database.php
        - lequocanh/cache/QueryCache.php
    ignoreErrors:
        # Classes loaded via require (not autoload) - legacy architecture
        - '#on an unknown class (Database|SessionManager|GioHang|CacheManager|ProductReview|hanghoa|ConfigManager|CorsMiddleware|ValidationMiddleware)#'
        - '#Instantiated class (GioHang|hanghoa|ProductReview|CorsMiddleware|ValidationMiddleware) not found#'
        # Firebase JWT - loaded via vendor but not in scanned paths
        - '#on an unknown class Firebase#'
        - '#Instantiated class Firebase#'
        # Active Record pattern - unsafe new static()
        - '#Unsafe usage of new static\(\)#'
        # Legacy properties accessed dynamically
        - '#Access to an undefined property Product::\$#'
        # Dead catch in try/catch (safeRedirect always exits)
        - '#Dead catch - Exception is never thrown#'
        # Defensive programming - comparison always true after validation
        - '#Comparison operation ">" between int<1, max> and 0 is always true#'
        # Properties written but read via reflection or future use
        - '#Property .+ is never read, only written#'
