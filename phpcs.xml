<?xml version="1.0"?>
<ruleset name="LQA Shop">
    <description>LQA Shop coding standard (PSR-12)</description>

    <!-- Paths to check -->
    <file>lequocanh/app</file>

    <!-- Exclude -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/cache/*</exclude-pattern>
    <exclude-pattern>*/graphify-out/*</exclude-pattern>
    <exclude-pattern>*.backup*</exclude-pattern>

    <!-- Use PSR-12 standard -->
    <rule ref="PSR12"/>

    <!-- Allow long lines (legacy code) -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="150"/>
            <property name="absoluteLineLimit" value="200"/>
        </properties>
    </rule>
</ruleset>
