# Application Environment
APP_ENV=development
APP_DEBUG=true
# ⚠️ CHỈ CHỈNH SỬA BASE_URL - APP_URL sẽ được tính tự động từ BASE_URL

# ===== CLOUDFLARE TUNNEL CONFIGURATION =====
# Đặt USE_CLOUDFLARE_TUNNEL=true để sử dụng Cloudflare tunnel
# Đặt USE_CLOUDFLARE_TUNNEL=false hoặc bỏ trống để sử dụng localhost (mặc định)
USE_CLOUDFLARE_TUNNEL=true

# URL Cloudflare Tunnel (chỉ cần chỉnh SỬA DÒNG NÀY - tất cả URL khác sẽ được tính từ đây)
# Để chạy tunnel: .\cloudflared.exe tunnel --url http://localhost:20080

# LƯU Ý: Chỉ cần domain, không cần thêm /lequocanh (hệ thống sẽ tự động thêm)
BASE_URL=   https://certified-jobs-hdtv-conditional.trycloudflare.com                        

# Legacy configuration (deprecated - sử dụng USE_CLOUDFLARE_TUNNEL thay thế)
FORCE_TUNNEL=false
FORCE_NGROK=false

