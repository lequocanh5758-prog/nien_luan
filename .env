# Cache Configuration
CACHE_DRIVER=file
CACHE_TTL=300

# Monitoring Configuration
MONITORING_ENABLED=true
PERFORMANCE_THRESHOLD=1.0
ERROR_REPORTING_LEVEL=E_ALL

# API Configuration
API_RATE_LIMIT=100
API_RATE_WINDOW=60

# CSRF Protection
# Set to 'false' để tắt CSRF trong development (không khuyến khích cho production)
# ĐÃ BẬT - Frontend đã được cập nhật với CSRF token
CSRF_ENABLED=true

