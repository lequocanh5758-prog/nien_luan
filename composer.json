{
    "name": "lequocanh/shop",
    "description": "LeQuocAnh Shop - E-commerce System",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "tecnickcom/tcpdf": "^6.6",
        "phpoffice/phpspreadsheet": "^1.29",
        "phpmailer/phpmailer": "^7.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "lequocanh/app/"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse lequocanh/app lequocanh/includes lequocanh/api --level=4 --memory-limit=256M",
        "cs-check": "phpcs lequocanh/app --standard=PSR12 --ignore=*/vendor/*",
        "cs-fix": "phpcbf lequocanh/app --standard=PSR12 --ignore=*/vendor/*"
    }
}
